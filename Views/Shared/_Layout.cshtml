<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - demomvcdata</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/demomvcdata.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">demomvcdata</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="ZonasInseguras" asp-action="Index">Zonas Inseguras</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Cookies">Cookies</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="zonaSeleccionadaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                📍 Zona Seleccionada
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="zonaSeleccionadaDropdown">
                                @{
                                    var zonaSeleccionadaJson = Context.Session.GetString("ZonaSeleccionada");
                                    if (!string.IsNullOrEmpty(zonaSeleccionadaJson))
                                    {
                                        var zonaSeleccionada = System.Text.Json.JsonSerializer.Deserialize<demomvcdata.Models.ZonaInsegura>(zonaSeleccionadaJson);
                                        if (zonaSeleccionada != null)
                                        {
                                            <li><h6 class="dropdown-header">@zonaSeleccionada.Nombre</h6></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><span class="dropdown-item-text"><strong>Dirección:</strong> @zonaSeleccionada.Direccion</span></li>
                                            <li><span class="dropdown-item-text"><strong>Nivel:</strong> @zonaSeleccionada.NivelPeligro</span></li>
                                            <li><span class="dropdown-item-text"><strong>Estado:</strong> @(zonaSeleccionada.Activa ? "Activa" : "Inactiva")</span></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" asp-area="" asp-controller="ZonasInseguras" asp-action="Details" asp-route-id="@zonaSeleccionada.Id">Ver Detalles</a></li>
                                        }
                                    }
                                    else
                                    {
                                        <li><span class="dropdown-item-text text-muted">No se ha seleccionado ninguna zona</span></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="ZonasInseguras" asp-action="Index">Ir a Zonas Inseguras</a></li>
                                    }
                                }
                            </ul>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - demomvcdata - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> - <a asp-area="" asp-controller="Home" asp-action="Cookies">Cookies</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
