@{
    ViewData["Title"] = "Cookies del Usuario";
}

<div class="text-center">
    <h1 class="display-4">@ViewData["Title"]</h1>
    <p class="lead">Información almacenada en cookies del navegador</p>
</div>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-cookie"></i> Datos de Cookies</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.UserEmail != "No disponible")
                    {
                        <div class="alert alert-success" role="alert">
                            <strong>Usuario autenticado:</strong> Se encontraron cookies de sesión
                        </div>
                        
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th scope="col">Cookie</th>
                                    <th scope="col">Valor</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Email del Usuario</strong></td>
                                    <td>@ViewBag.UserEmail</td>
                                </tr>
                                <tr>
                                    <td><strong>ID del Usuario</strong></td>
                                    <td><code>@ViewBag.UserId</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Nombre de Usuario</strong></td>
                                    <td>@ViewBag.UserName</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <div class="mt-3">
                            <h6>Información de Seguridad:</h6>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">
                                    <i class="bi bi-shield-check text-success"></i> 
                                    <strong>HttpOnly:</strong> Protección contra ataques XSS
                                </li>
                                <li class="list-group-item">
                                    <i class="bi bi-lock text-success"></i> 
                                    <strong>Secure:</strong> Transmisión solo por HTTPS
                                </li>
                                <li class="list-group-item">
                                    <i class="bi bi-shield-lock text-success"></i> 
                                    <strong>SameSite:</strong> Protección contra CSRF
                                </li>
                                <li class="list-group-item">
                                    <i class="bi bi-clock text-info"></i> 
                                    <strong>Expiración:</strong> 7 días desde el inicio de sesión
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning" role="alert">
                            <h5 class="alert-heading">No hay cookies de usuario</h5>
                            <p>No se encontraron cookies de sesión. Por favor, inicia sesión para ver tu información.</p>
                            <hr>
                            <p class="mb-0">
                                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">
                                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                                </a>
                            </p>
                        </div>
                        
                        <div class="mt-3">
                            <h6>¿Qué son las cookies?</h6>
                            <p class="text-muted">
                                Las cookies son pequeños archivos de texto que se almacenan en tu navegador 
                                para recordar información sobre tu sesión, preferencias y datos de autenticación.
                            </p>
                        </div>
                    }
                </div>
                <div class="card-footer text-muted text-center">
                    <small>Las cookies se gestionan de forma segura y protegida</small>
                </div>
            </div>
        </div>
    </div>
</div>
